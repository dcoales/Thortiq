{
  "name": "thortiq",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --build",
    "test": "jest --runInBand --passWithNoTests",
    "sync:local": "node scripts/start-local-sync-server.js",
    "prepare": "husky install"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "6.4.3",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "29.5.12",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.2",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.3",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.5.4",
    "vite": "^7.1.7",
    "fake-indexeddb": "5.0.2"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
